#!/usr/bin/env bash
# Trigger a release by firing the workflow_dispatch event on release.yml.
#
# Layer 0 release-trigger primitive — see lex-fmt/lex#640.
#
# Strategy: **workflow_dispatch**. This repo's release CI
# (.github/workflows/release.yml) is wired to:
#     on: workflow_dispatch
# matching the cross-repo cascade-handler trigger contract used by the
# release-lex orchestrator. The release workflow is a thin caller of
# arthur-debert/release/.github/workflows/nvim-plugin.yml@v1 which
# handles the version bump, changelog roll, tag + push, and GH release.
#
# Migration note (2026-05-18): previously this primitive used the
# tag-push strategy. The migration to release@v1 moved the trigger
# contract to workflow_dispatch — same as vscode, mkdocs-lex, and
# tree-sitter-lex.
#
# Called by the release orchestrator after the version-bump PR has merged
# to main: the orchestrator runs `get-current-version` on the freshly
# merged main to confirm the bumped version, then invokes this script
# with that version. The reusable workflow takes over from there.
#
# This script does NOT bump versions, edit files, or push commits.

set -euo pipefail

if ! command -v gh >/dev/null 2>&1; then
  echo "error: gh is required but not installed" >&2
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
cd "$REPO_ROOT"

usage() {
  echo "Usage: $(basename "$0") <new-version>" >&2
  echo "  new-version   Bare semver string, e.g. 0.10.2 (no leading v)" >&2
}

[[ $# -ne 1 ]] && { usage; exit 2; }
NEW_VERSION="$1"
# Strict SemVer 2.0.0 — dot-separated alphanumeric identifier segments;
# no leading zeros in numeric segments (except the literal "0"); no
# empty segments. Build-metadata (`+…`) intentionally not accepted —
# we don't use it in any release flow.
if ! [[ "${NEW_VERSION}" =~ ^[0-9]+\.[0-9]+\.[0-9]+(-[0-9A-Za-z-]+(\.[0-9A-Za-z-]+)*)?$ ]]; then
  echo "error: version must be X.Y.Z[-PRERELEASE] (got: ${NEW_VERSION})" >&2
  exit 2
fi

echo "Triggering release workflow for v${NEW_VERSION}..."
gh workflow run release.yml -f "version=${NEW_VERSION}"
echo "Done. CI should pick it up shortly."
echo "Watch: gh run list --workflow=release.yml --limit 1"
