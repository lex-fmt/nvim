#!/usr/bin/env bash
# Print this repo's current version (bare, no `v` prefix) to stdout.
#
# Source of truth: the `M.version = "X.Y.Z"` line in `lua/lex/init.lua`.
# Layer 0 release primitive — see lex-fmt/lex#640.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

INIT_LUA="$REPO_ROOT/lua/lex/init.lua"
if [[ ! -f "$INIT_LUA" ]]; then
  echo "error: $INIT_LUA not found" >&2
  exit 1
fi

VERSION=$(grep -E 'M\.version = "' "$INIT_LUA" | sed -E 's/.*"([^"]+)".*/\1/' | head -1)

if [[ -z "$VERSION" ]]; then
  echo "error: could not parse M.version from $INIT_LUA" >&2
  exit 1
fi

printf '%s\n' "$VERSION"
