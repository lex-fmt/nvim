#!/usr/bin/env bash
set -euo pipefail

# Canonical nvim-plugin check entry point. Same script local + CI.
#
# Delegates to the consumer's app-bin/test-all if present (the
# common pattern for Lua plugins with bats-driven tests), else
# falls back to invoking busted directly on tests/.
#
# Most nvim-plugin consumers in this portfolio use bats to drive
# Neovim under test (matches the shell-subshell isolation pattern
# used by other Bash-tested stacks). app-bin/test-all is the
# canonical entry point for that.
#
# Usage:
#   bin/check                # full suite
#   bin/check --filter foo   # consumer-side app-bin/test-all forwards
#
# Source of truth: arthur-debert/release templates/nvim-plugin/bin/check.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$REPO_ROOT"

# The gate runs first (one definition, via commons/bin/check-gate), then the
# Kind-specific test step. The test step below execs, so the gate must precede it.
"$SCRIPT_DIR/check-gate"

if [ -x app-bin/test-all ]; then
    exec app-bin/test-all "$@"
fi

if [ -d tests ] && command -v busted >/dev/null 2>&1; then
    exec busted tests "$@"
fi

echo "bin/check: no app-bin/test-all and no busted+tests/ — nothing to do."
echo "  Wire app-bin/test-all in this repo to give bin/check something to delegate to."
