#!/usr/bin/env bash
# Trigger a release by tagging HEAD `vX.Y.Z` and pushing the tag to origin.
#
# Layer 0 release-trigger primitive — see lex-fmt/lex#640.
#
# Strategy: **tag-push**. This repo's release workflow (`.github/workflows/`)
# fires on `on: push: tags: [v*]`, so creating and pushing the tag is the
# entire trigger. There is no separate dispatch step.
#
# Called by the release orchestrator after the version-bump PR has merged
# to main: the orchestrator runs `get-current-version` on the freshly merged
# main to confirm the bumped version, then invokes this script with that
# version. CI then takes over (build, publish, GitHub release).
#
# This script does NOT bump versions, edit files, or push commits — that's
# the version-bump primitive's job. It only tags and pushes.

set -euo pipefail

usage() {
  echo "Usage: $(basename "$0") <new-version>" >&2
  echo "  new-version   Bare semver string, e.g. 0.10.1 (no leading v)" >&2
}

[[ $# -ne 1 ]] && { usage; exit 2; }
NEW_VERSION="$1"
[[ ! "$NEW_VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]] && { echo "error: version must be X.Y.Z" >&2; exit 2; }

TAG="v$NEW_VERSION"
if git rev-parse "$TAG" >/dev/null 2>&1; then
  echo "error: tag $TAG already exists locally — delete it or pick a new version" >&2
  exit 1
fi

echo "Tagging $TAG on $(git rev-parse --short HEAD)..."
git tag "$TAG"
echo "Pushing $TAG to origin..."
git push origin "$TAG"
echo "Done. CI should pick it up shortly."
